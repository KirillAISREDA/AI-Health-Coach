# ─── Telegram ───────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=some_random_secret_string

# ─── OpenAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1000

# ─── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=healthcoach
POSTGRES_USER=healthcoach
POSTGRES_PASSWORD=strongpassword

# ─── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ─── App ────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# Context window: сколько последних сообщений помнит бот
CONTEXT_MESSAGES_LIMIT=15
# TTL контекста в Redis (секунды) — 24 часа
CONTEXT_TTL=86400

# Режим запуска:
#   polling (dev):  python -m bot.main
#   webhook (prod): uvicorn bot.webhook:app --host 0.0.0.0 --port 8080
BOT_COMMAND=python -m bot.main
